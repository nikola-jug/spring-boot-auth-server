# Client secrets for BFF registrations.
# Copy this file to .env and adjust values for your environment.
# For local development, {noop} prefix means plaintext comparison (no hashing).
# In production, use a proper password encoder (e.g. BCrypt) and inject secrets
# via your platform's secret manager — never commit .env to version control.

WEB_BFF_CLIENT_SECRET={noop}spring-boot-web-bff-auth-server-secret
MOBILE_BFF_CLIENT_SECRET={noop}spring-boot-mobile-bff-auth-server-secret
